#!/usr/bin/env bash
# ══════════════════════════════════════════════════════════════════════════════
# pai-sync — home machine PAI sync script
#
# DEPLOY TO:  ~/.local/bin/pai-sync
# MAKE EXEC:  chmod +x ~/.local/bin/pai-sync
#
# USE INSTEAD OF: git pull / git fetch in ~/.claude
# HOME MACHINE ONLY: home CLAUDE.md is canonical upstream — pulls as-is.
#   No zone-protection logic needed (see PAI/PROFILES/work/pai-sync for that).
#
# PURPOSE:
#   Fetches and rebases PAI from Forgejo, discarding known auto-generated
#   and runtime state files that diverge independently on each machine and
#   would cause conflicts on every pull. Regenerates ARCHITECTURE_SUMMARY.md
#   after the pull and commits if it changed.
#
# AUTO-DISCARDED FILES (machine-local, not cross-machine config):
#   - PAI/DOCUMENTATION/ARCHITECTURE_SUMMARY.md   (regenerated by hooks)
#   - PAI/PULSE/state/*.json + *.jsonl             (Pulse runtime state)
#   - PAI/PULSE/Performance/aggregator-state.json (Pulse perf state)
#   - PAI/USER/TELOS/PAI_STATE.json               (telos interview state)
#   - cache/changelog.md                          (cache file)
#   - plugins/*.json                              (plugin registry — see warning)
#   - plugins/marketplaces/                       (marketplace data)
#   - PAI/PULSE/Observability/out/                (static build artifacts — intentionally
#           tracked for fresh-install distribution; reset here to avoid local diffs)
#
# ONGOING:
#   pai-sync   ← pull framework updates from Forgejo (replaces git pull)
# ══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

CLAUDE_DIR="${HOME}/.claude"
REMOTE="origin"
BRANCH="main"
UPSTREAM="${REMOTE}/${BRANCH}"

# ── 1. Fetch ──────────────────────────────────────────────────────────────────
echo "Fetching ${UPSTREAM}..."
git -C "${CLAUDE_DIR}" fetch "${REMOTE}"

LOCAL=$(git -C "${CLAUDE_DIR}" rev-parse HEAD)
REMOTE=$(git -C "${CLAUDE_DIR}" rev-parse "${UPSTREAM}")

if [ "${LOCAL}" = "${REMOTE}" ]; then
  echo "Already up to date."
  exit 0
fi

# ── 2. Reset known auto-generated and runtime state files ─────────────────────
# These files regenerate independently on each machine — discarding local
# versions before the pull prevents conflicts on every sync.

RESET_FILES=(
  "PAI/DOCUMENTATION/ARCHITECTURE_SUMMARY.md"
  "PAI/PULSE/state/state.json"   # NOTE: don't run pai-sync while Pulse is writing (race)
  "PAI/PULSE/state/da/diary.jsonl"
  "PAI/PULSE/Performance/aggregator-state.json"
  "PAI/USER/TELOS/PAI_STATE.json"
  "cache/changelog.md"
)

# Plugin files: tracked but auto-managed — warn when discarding so intentional
# plugin changes aren't silently dropped.
PLUGIN_FILES=(
  "plugins/installed_plugins.json"
  "plugins/known_marketplaces.json"
)

echo ""
echo "Resetting auto-generated and state files..."

for f in "${RESET_FILES[@]}"; do
  if git -C "${CLAUDE_DIR}" ls-files --error-unmatch "${f}" &>/dev/null 2>&1; then
    git -C "${CLAUDE_DIR}" checkout HEAD -- "${f}" && echo "  ✓ reset: ${f}"
  fi
done

for f in "${PLUGIN_FILES[@]}"; do
  if git -C "${CLAUDE_DIR}" ls-files --error-unmatch "${f}" &>/dev/null 2>&1; then
    echo "  ⚠  resetting plugin file (check for intentional changes): ${f}"
    git -C "${CLAUDE_DIR}" checkout HEAD -- "${f}"
  fi
done

# Reset marketplace data directory (multiple nested files)
if [ -d "${CLAUDE_DIR}/plugins/marketplaces" ]; then
  git -C "${CLAUDE_DIR}" checkout HEAD -- plugins/marketplaces/ 2>/dev/null \
    && echo "  ✓ reset: plugins/marketplaces/" || true
fi

# Reset Observability build artifacts (60+ static export files).
# Intentionally tracked for public release distribution; reset to avoid local diffs on pull.
if [ -d "${CLAUDE_DIR}/PAI/PULSE/Observability/out" ]; then
  git -C "${CLAUDE_DIR}" checkout HEAD -- PAI/PULSE/Observability/out/ 2>/dev/null \
    && echo "  ✓ reset: PAI/PULSE/Observability/out/ (build artifacts)" || true
fi

# ── 3. Pull with rebase ───────────────────────────────────────────────────────
echo ""
echo "Rebasing onto ${UPSTREAM}..."
if ! git -C "${CLAUDE_DIR}" pull --rebase "${REMOTE}" "${BRANCH}"; then
  echo ""
  echo "⚠  Rebase failed — a non-auto-gen file has a real conflict."
  echo "   Resolve conflicts, then: git -C ~/.claude rebase --continue"
  echo "   Or abort with:           git -C ~/.claude rebase --abort"
  exit 1
fi

# ── 4. Regenerate ARCHITECTURE_SUMMARY.md ────────────────────────────────────
echo ""
echo "Regenerating ARCHITECTURE_SUMMARY.md..."
if bun "${CLAUDE_DIR}/PAI/TOOLS/ArchitectureSummaryGenerator.ts" generate 2>/dev/null; then
  if ! git -C "${CLAUDE_DIR}" diff --quiet PAI/DOCUMENTATION/ARCHITECTURE_SUMMARY.md; then
    git -C "${CLAUDE_DIR}" add PAI/DOCUMENTATION/ARCHITECTURE_SUMMARY.md
    git -C "${CLAUDE_DIR}" commit -m "chore(auto): regenerate ARCHITECTURE_SUMMARY after pai-sync"
    echo "✓ ARCHITECTURE_SUMMARY.md regenerated and committed"
  else
    echo "✓ ARCHITECTURE_SUMMARY.md unchanged"
  fi
else
  echo "⚠  ArchitectureSummaryGenerator failed — skipping (sync still complete)"
fi

echo ""
echo "✓ PAI synced — recent commits:"
git -C "${CLAUDE_DIR}" log --oneline -5
